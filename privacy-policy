<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Privacy Policy for Bashar Marji personal portfolio website" />
  <title>Privacy Policy | Bashar Marji</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64," />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#07111f;
      --bg-2:#0b1728;
      --paper:#f4f7fb;
      --white:#ffffff;
      --text:#0f1724;
      --muted:#6a7483;
      --blue:#2FBAFF;
      --blue-dark:#0f84c5;
      --line:rgba(255,255,255,.10);
      --line-soft:rgba(15,23,36,.10);
      --shadow:0 20px 70px rgba(0,0,0,.18);
      --radius:24px;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}

    body{
      font-family:"Manrope",sans-serif;
      background:linear-gradient(180deg, #06101d 0%, #0a1526 100%);
      color:var(--white);
      line-height:1.6;
      overflow-x:hidden;
    }

    .cursor-glow{
      position:fixed;
      width:340px;
      height:340px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(47,186,255,.18), transparent 65%);
      transform:translate(-50%, -50%);
      pointer-events:none;
      z-index:2;
      mix-blend-mode:screen;
    }

    .container{
      width:min(1240px, calc(100% - 40px));
      margin:0 auto;
    }

    .page{
      display:none;
      animation:fade .45s ease both;
    }

    .page.active{
      display:block;
    }

    @keyframes fade{
      from{opacity:0; transform:translateY(14px);}
      to{opacity:1; transform:translateY(0);}
    }

    /* Top nav */
    .nav-wrap{
      position:sticky;
      top:0;
      z-index:50;
      backdrop-filter:blur(14px);
      background:rgba(6,16,29,.78);
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .home-active .nav-wrap{
      display:none;
    }


    .main-nav{
      min-height:78px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      background:transparent;
      border:0;
      cursor:pointer;
      color:#fff;
      font:inherit;
      font-weight:800;
      letter-spacing:-.02em;
    }



    .brand-logo{
      display:block;
      height:42px;
      width:auto;
      object-fit:contain;
    }

    .hero-logo{
      display:block;
      height:46px;
      width:auto;
      object-fit:contain;
    }

    .brand-mark{
      width:42px;
      height:42px;
      border-radius:50%;
      display:grid;
      place-items:center;
      color:#02101c;
      font-weight:900;
      background:linear-gradient(135deg, #effbff, var(--blue));
      box-shadow:0 10px 26px rgba(47,186,255,.28);
    }

    .nav-links{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
    }

    .nav-btn{
      border:0;
      background:transparent;
      color:#d9e6f5;
      padding:10px 14px;
      border-radius:999px;
      cursor:pointer;
      font:inherit;
      font-weight:700;
      transition:.25s ease;
    }

    .nav-btn:hover{
      color:#fff;
      background:rgba(47,186,255,.12);
    }

    .nav-btn.active{
      background:rgba(47,186,255,.22);
      color:#fff;
      box-shadow:inset 0 0 0 1px rgba(47,186,255,.18);
    }

    .nav-btn.cta{
      background:var(--blue);
      color:#03111d;
      font-weight:800;
    }

    .nav-btn.cta:hover{
      background:#5bc9ff;
      color:#03111d;
    }

    /* Home hero */
    .hero-section{
      padding:30px 0 46px;
      position:relative;
      overflow:hidden;
    }

    .home-orbs{
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      overflow:hidden;
    }

    .home-orb{
      position:absolute;
      border-radius:50%;
      background:radial-gradient(circle at 35% 30%, rgba(124,221,255,.68), rgba(47,186,255,.18) 42%, rgba(47,186,255,.03) 72%);
      border:1px solid rgba(47,186,255,.15);
      box-shadow:0 0 80px rgba(47,186,255,.18);
      opacity:.34;
      mix-blend-mode:screen;
      filter:blur(.2px);
      animation:homeOrbFloat 9s ease-in-out infinite;
    }

    .home-orb.one{
      width:260px;
      height:260px;
      left:2%;
      top:17%;
    }

    .home-orb.two{
      width:330px;
      height:330px;
      right:-5%;
      top:44%;
      opacity:.24;
      animation-delay:-2s;
    }

    .home-orb.three{
      width:170px;
      height:170px;
      left:44%;
      bottom:4%;
      opacity:.20;
      animation-delay:-4s;
    }

    .home-orb-slogan{
      position:absolute;
      left:50%;
      top:56%;
      transform:translate(-50%, -50%);
      width:min(880px, 86vw);
      text-align:center;
      color:rgba(255,255,255,.075);
      font-size:clamp(38px, 6vw, 92px);
      line-height:.92;
      letter-spacing:-.065em;
      font-weight:900;
      text-shadow:0 0 55px rgba(47,186,255,.12);
      user-select:none;
      animation:homeSloganPulse 8s ease-in-out infinite;
    }

    @keyframes homeOrbFloat{
      0%,100%{transform:translate3d(0,0,0) scale(1);}
      50%{transform:translate3d(22px,-18px,0) scale(1.06);}
    }

    @keyframes homeSloganPulse{
      0%,100%{opacity:.72; filter:blur(0);}
      50%{opacity:1; filter:blur(.3px);}
    }

    .hero-section > .container{
      position:relative;
      z-index:1;
    }

    .hero-frame{
      background:#fff;
      border-radius:22px;
      overflow:hidden;
      box-shadow:0 30px 80px rgba(0,0,0,.25);
      border:1px solid rgba(255,255,255,.08);
    }

    .browser-bar{
      background:#dbe2e8;
      min-height:78px;
      padding:0 26px;
      display:flex;
      align-items:center;
      border-bottom:1px solid rgba(255,255,255,.35);
    }

    .browser-dots{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .dot{
      width:24px;
      height:24px;
      border-radius:50%;
    }

    .dot.red{background:#f77a77;}
    .dot.yellow{background:#f0c15c;}
    .dot.green{background:#66d87b;}

    .hero-top-nav{
      background:#f6f8fb;
      min-height:106px;
      display:grid;
      grid-template-columns:1fr auto 1fr;
      gap:18px;
      align-items:center;
      padding:0 34px;
      border-bottom:1px solid #e7edf3;
      color:#111827;
    }

    .hero-menu-left,
    .hero-menu-right{
      display:flex;
      align-items:center;
      gap:18px;
      flex-wrap:wrap;
    }

    .hero-menu-right{
      justify-content:flex-end;
    }

    .mini-link{
      border:0;
      background:transparent;
      cursor:pointer;
      font:inherit;
      font-size:15px;
      color:#182535;
      transition:.25s ease;
    }

    .mini-link:hover{
      color:var(--blue-dark);
    }

    .hero-name{
      font-size:34px;
      font-weight:900;
      letter-spacing:-.04em;
      color:#0f1724;
      text-align:center;
      white-space:nowrap;
    }

    .mini-pill{
      border:0;
      border-radius:14px;
      padding:14px 22px;
      background:var(--blue);
      color:#04121d;
      font:inherit;
      font-weight:800;
      cursor:pointer;
      transition:.25s ease;
    }

    .mini-pill:hover{
      background:#5bc9ff;
    }

    .contact-mini-pill{
      display:inline-flex;
      align-items:center;
      gap:10px;
      overflow:hidden;
    }

    .contact-pulse-icon{
      width:26px;
      height:26px;
      border-radius:50%;
      display:grid;
      place-items:center;
      background:rgba(4,18,29,.12);
      color:#04121d;
      animation:contactIconPulse 1.9s ease-in-out infinite;
    }

    .contact-pulse-icon svg{
      animation:contactArrowMove 1.4s ease-in-out infinite;
    }

    @keyframes contactIconPulse{
      0%,100%{ transform:scale(1); box-shadow:0 0 0 0 rgba(47,186,255,.35); }
      50%{ transform:scale(1.08); box-shadow:0 0 0 8px rgba(47,186,255,0); }
    }

    @keyframes contactArrowMove{
      0%,100%{ transform:translateX(0); }
      50%{ transform:translateX(3px); }
    }


    .hero-main{
      min-height:720px;
      display:grid;
      grid-template-columns:1fr 1fr;
      align-items:center;
      gap:30px;
      padding:40px 46px 42px;
      background:
        radial-gradient(circle at 80% 20%, rgba(47,186,255,.12), transparent 28%),
        radial-gradient(circle at 20% 80%, rgba(47,186,255,.08), transparent 24%),
        linear-gradient(135deg, #050914 0%, #08111e 55%, #050914 100%);
    }

    .hero-copy{
      color:#fff;
      padding-left:6px;
      position:relative;
      z-index:3;
    }

    .hero-title{
      font-family:"Cormorant Garamond",serif;
      font-size:clamp(64px, 6vw, 96px);
      line-height:.93;
      letter-spacing:-.035em;
      text-transform:uppercase;
      margin-bottom:24px;
    }

    .hero-title span{
      display:block;
    }

    .hero-sub{
      font-size:clamp(18px, 2vw, 23px);
      line-height:1.45;
      max-width:560px;
      color:#eef6ff;
      margin-bottom:16px;
      font-weight:500;
    }

    .hero-description{
      max-width:540px;
      color:#b6c5d5;
      font-size:16px;
      margin-bottom:28px;
    }

    .hero-actions{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
    }

    .btn{
      border:0;
      cursor:pointer;
      font:inherit;
      font-weight:800;
      padding:14px 20px;
      border-radius:999px;
      transition:.25s ease;
    }

    .btn-primary{
      background:var(--blue);
      color:#04121d;
      box-shadow:0 16px 30px rgba(47,186,255,.22);
    }

    .btn-primary:hover{
      transform:translateY(-2px);
      background:#63ccff;
    }

    .btn-secondary{
      background:rgba(255,255,255,.06);
      color:#fff;
      border:1px solid rgba(255,255,255,.12);
    }

    .btn-secondary:hover{
      background:rgba(47,186,255,.10);
      border-color:rgba(47,186,255,.24);
    }

    .hero-image-wrap{
      min-height:620px;
      display:flex;
      align-items:flex-end;
      justify-content:center;
      position:relative;
      overflow:hidden;
    }

    .hero-image-wrap::before{
      content:"";
      position:absolute;
      width:560px;
      height:560px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(47,186,255,.18), transparent 65%);
      top:30px;
      right:20px;
      filter:blur(18px);
      z-index:1;
    }

    .hero-image-wrap::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(to bottom, transparent 0%, transparent 68%, #050914 100%),
        linear-gradient(to right, transparent 0%, transparent 84%, #050914 100%);
      z-index:3;
      pointer-events:none;
    }

    .hero-photo{
      position:relative;
      z-index:2;
      max-height:660px;
      max-width:100%;
      width:auto;
      object-fit:contain;
      filter:drop-shadow(0 24px 40px rgba(0,0,0,.28));
    }

    /* Generic light pages */
    .light-page{
      background:var(--paper);
      min-height:calc(100vh - 78px);
      color:var(--text);
    }

    .section{
      padding:84px 0;
    }

    .section-head{
      max-width:760px;
      margin-bottom:36px;
    }

    .kicker{
      text-transform:uppercase;
      letter-spacing:.14em;
      font-size:12px;
      font-weight:800;
      color:var(--blue-dark);
      margin-bottom:12px;
    }

    .section h2{
      font-size:clamp(34px, 4vw, 60px);
      line-height:1.04;
      letter-spacing:-.045em;
      margin-bottom:12px;
      color:#0d1726;
    }

    .section-head p{
      color:var(--muted);
      font-size:18px;
    }

    .grid-3{
      display:grid;
      grid-template-columns:repeat(3, 1fr);
      gap:18px;
    }

    .card{
      background:#fff;
      border:1px solid var(--line-soft);
      border-radius:24px;
      padding:28px;
      box-shadow:0 12px 28px rgba(5,9,20,.05);
      transition:.3s ease;
    }

    .card:hover{
      transform:translateY(-6px);
      box-shadow:0 18px 40px rgba(5,9,20,.08);
      border-color:rgba(47,186,255,.28);
    }

    .icon{
      width:54px;
      height:54px;
      border-radius:16px;
      display:grid;
      place-items:center;
      font-weight:900;
      font-size:22px;
      color:var(--blue-dark);
      background:rgba(47,186,255,.10);
      margin-bottom:16px;
    }

    .card h3{
      font-size:24px;
      line-height:1.15;
      letter-spacing:-.03em;
      color:#0f1724;
      margin-bottom:10px;
    }

    .card p{
      color:var(--muted);
      font-size:15px;
    }


    /* Professional focus areas section */
    .consulting-page-shell{
      background:
        radial-gradient(circle at 12% 18%, rgba(47,186,255,.14), transparent 28%),
        radial-gradient(circle at 88% 78%, rgba(47,186,255,.10), transparent 34%),
        linear-gradient(135deg, #050914 0%, #08111e 58%, #050914 100%);
      color:#fff;
      min-height:calc(100vh - 78px);
      padding:84px 0 96px;
      position:relative;
      overflow:hidden;
    }

    .consulting-page-shell::before{
      content:"";
      position:absolute;
      inset:0;
      opacity:.13;
      background-image:
        linear-gradient(rgba(255,255,255,.14) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.14) 1px, transparent 1px);
      background-size:72px 72px;
      pointer-events:none;
    }

    .consulting-page-shell .container{ position:relative; z-index:2; }

    .consulting-heading{
      display:grid;
      grid-template-columns:120px 1fr;
      gap:28px;
      align-items:start;
      margin-bottom:46px;
    }

    .consulting-heading-line{
      width:100%;
      height:2px;
      background:linear-gradient(90deg, var(--blue), transparent);
      margin-top:20px;
      box-shadow:0 0 28px rgba(47,186,255,.45);
    }

    .consulting-heading h2{
      font-size:clamp(42px, 5vw, 78px);
      line-height:.98;
      letter-spacing:-.06em;
      color:#fff;
      max-width:920px;
    }

    .consulting-heading p{
      color:#b6c5d5;
      font-size:18px;
      max-width:720px;
      margin-top:16px;
    }

    .capabilities-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:18px;
    }

    .capability-card{
      min-height:230px;
      display:grid;
      grid-template-columns:96px 1fr;
      gap:20px;
      align-items:start;
      padding:24px;
      border-radius:28px;
      background:rgba(255,255,255,.065);
      border:1px solid rgba(255,255,255,.12);
      box-shadow:0 24px 70px rgba(0,0,0,.22);
      position:relative;
      overflow:hidden;
      transition:transform .32s ease, border-color .32s ease, background .32s ease;
    }

    .capability-card::before{
      content:"";
      position:absolute;
      inset:0;
      opacity:0;
      background:radial-gradient(circle at 20% 10%, rgba(47,186,255,.22), transparent 38%);
      transition:opacity .32s ease;
    }

    .capability-card:hover{
      transform:translateY(-8px);
      background:rgba(255,255,255,.09);
      border-color:rgba(47,186,255,.34);
    }

    .capability-card:hover::before{ opacity:1; }
    .capability-icon, .capability-content{ position:relative; z-index:2; }

    .capability-icon{
      width:90px;
      height:90px;
      border-radius:24px;
      display:grid;
      place-items:center;
      background:rgba(47,186,255,.10);
      border:1px solid rgba(47,186,255,.24);
      box-shadow:inset 0 0 22px rgba(47,186,255,.06);
    }

    .capability-icon svg{ width:62px; height:62px; overflow:visible; }

    .capability-icon .icon-stroke{ stroke:#DFFBFF; stroke-width:2.2; stroke-linecap:round; stroke-linejoin:round; fill:none; }
    .capability-icon .icon-fill{ fill:#4FDFFF; }
    .capability-icon .icon-soft-fill{ fill:rgba(79,223,255,.18); stroke:rgba(223,251,255,.75); stroke-width:1.6; }

    .capability-card:hover .capability-icon{ box-shadow:inset 0 0 28px rgba(47,186,255,.10), 0 0 30px rgba(47,186,255,.16); }

    .icon-excellence .ring{ transform-origin:45px 45px; animation:iconSpin 8s linear infinite; }
    .icon-excellence .spark{ transform-origin:45px 45px; animation:iconPulse 2.2s ease-in-out infinite; }

    .icon-standards .shield{ animation:iconFloatY 3s ease-in-out infinite; }
    .icon-standards .check{ stroke-dasharray:16; stroke-dashoffset:16; animation:drawCheck 2.6s ease-in-out infinite; }
    .icon-standards .dots circle{ animation:dotBlink 1.8s ease-in-out infinite; }
    .icon-standards .dots circle:nth-child(2){ animation-delay:.25s; }
    .icon-standards .dots circle:nth-child(3){ animation-delay:.5s; }

    .icon-strategy .orbit{ transform-origin:45px 45px; animation:iconSpin 7s linear infinite; }
    .icon-strategy .arrow{ animation:iconFloatY 2.2s ease-in-out infinite; }

    .icon-performance .bar{ transform-box:fill-box; transform-origin:center bottom; animation:barsGrow 2.4s ease-in-out infinite; }
    .icon-performance .bar2{ animation-delay:.18s; }
    .icon-performance .bar3{ animation-delay:.34s; }
    .icon-performance .line-dot{ animation:dotTravel 2.8s ease-in-out infinite; }

    .icon-governance .node{ animation:nodePulse 2.2s ease-in-out infinite; }
    .icon-governance .node.n2{ animation-delay:.2s; }
    .icon-governance .node.n3{ animation-delay:.4s; }
    .icon-governance .node.n4{ animation-delay:.6s; }
    .icon-governance .node.n5{ animation-delay:.8s; }

    .icon-foresight .scan{ animation:scanMove 2.6s ease-in-out infinite; }
    .icon-foresight .pulse-ring{ transform-origin:45px 45px; animation:pulseRing 2.8s ease-out infinite; }
    .icon-foresight .star{ animation:starTwinkle 2s ease-in-out infinite; }

    @keyframes iconSpin{
      from{ transform:rotate(0deg); }
      to{ transform:rotate(360deg); }
    }

    @keyframes iconPulse{
      0%,100%{ transform:scale(1); opacity:1; }
      50%{ transform:scale(1.12); opacity:.7; }
    }

    @keyframes iconFloatY{
      0%,100%{ transform:translateY(0); }
      50%{ transform:translateY(-3px); }
    }

    @keyframes drawCheck{
      0%,15%{ stroke-dashoffset:16; }
      35%,80%{ stroke-dashoffset:0; }
      100%{ stroke-dashoffset:-16; }
    }

    @keyframes dotBlink{
      0%,100%{ opacity:.28; }
      50%{ opacity:1; }
    }

    @keyframes barsGrow{
      0%,100%{ transform:scaleY(.65); opacity:.82; }
      50%{ transform:scaleY(1.08); opacity:1; }
    }

    @keyframes dotTravel{
      0%{ transform:translate(0, 0); }
      35%{ transform:translate(5px,-6px); }
      70%{ transform:translate(11px,-1px); }
      100%{ transform:translate(0,0); }
    }

    @keyframes nodePulse{
      0%,100%{ transform:scale(1); opacity:.78; }
      50%{ transform:scale(1.18); opacity:1; }
    }

    @keyframes scanMove{
      0%,100%{ transform:translateX(-6px); opacity:.35; }
      50%{ transform:translateX(8px); opacity:1; }
    }

    @keyframes pulseRing{
      0%{ transform:scale(.78); opacity:.85; }
      100%{ transform:scale(1.22); opacity:0; }
    }

    @keyframes starTwinkle{
      0%,100%{ transform:scale(1) rotate(0deg); opacity:.95; }
      50%{ transform:scale(1.18) rotate(8deg); opacity:.62; }
    }

    .capability-number{
      width:46px;
      height:46px;
      border-radius:50%;
      display:grid;
      place-items:center;
      color:#03111d;
      background:var(--blue);
      font-weight:900;
      font-size:14px;
      margin-bottom:16px;
      box-shadow:0 0 32px rgba(47,186,255,.26);
    }

    .capability-card h3{
      color:#fff;
      font-size:clamp(22px, 2.2vw, 32px);
      line-height:1.08;
      letter-spacing:-.045em;
      margin-bottom:12px;
    }

    .capability-card p{ color:#b6c5d5; font-size:15px; }



    /* Unified dark-blue theme for About, Training, Blog, and Contact pages */
    .light-page{
      background:
        radial-gradient(circle at 12% 18%, rgba(47,186,255,.14), transparent 28%),
        radial-gradient(circle at 88% 78%, rgba(47,186,255,.10), transparent 34%),
        linear-gradient(135deg, #050914 0%, #08111e 58%, #050914 100%);
      color:#fff;
      position:relative;
      overflow:hidden;
    }

    .light-page::before{
      content:"";
      position:absolute;
      inset:0;
      opacity:.13;
      background-image:
        linear-gradient(rgba(255,255,255,.14) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.14) 1px, transparent 1px);
      background-size:72px 72px;
      pointer-events:none;
    }

    .light-page .section{
      position:relative;
      z-index:2;
    }

    .light-page .section h2,
